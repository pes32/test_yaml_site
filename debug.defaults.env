YAMLS_ENV=development
YAMLS_ENABLE_DEBUG_ROUTES=1
YAMLS_CONFIG_LIVE_RELOAD=1
YAMLS_CONFIG_SCAN_INTERVAL=0.5
YAMLS_TRUST_PROXY=1
YAMLS_TRUSTED_PROXY=127.0.0.1

YAMLS_WAITRESS_HOST=127.0.0.1
YAMLS_WAITRESS_PORT=8080

YAMLS_NGINX_BIND_HOST=127.0.0.1
YAMLS_NGINX_PORT=8443
YAMLS_SERVER_NAME=localhost
YAMLS_HEALTHCHECK_CONNECT_HOST=127.0.0.1

YAMLS_NGINX_BIND_HOST=0.0.0.0
