{
  "name": "yaml-system",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "type-holes": "node scripts/check-type-holes.mjs",
    "preflight": "npm run type-holes && npm run typecheck:table && npm run typecheck && npm run build",
    "typecheck": "vue-tsc --noEmit -p ../../tsconfig.json",
    "typecheck:table": "vue-tsc --noEmit -p ../../tsconfig.table.json"
  },
  "dependencies": {
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vue-tsc": "^3.2.6"
  }
}
