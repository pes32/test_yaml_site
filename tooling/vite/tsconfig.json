{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": []
  },
  "files": [
    "src/entry/page.ts",
    "src/entry/debug.ts",
    "src/contracts/api.ts",
    "src/contracts/table.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}
